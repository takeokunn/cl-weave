(progn (require :asdf) (asdf:load-system "cl-weave") (defparameter *n* 1000) (defparameter *sink* (make-broadcast-stream)) (eval `(cl-weave:describe "detail-optimized" (cl-weave:it "case" (dotimes (i ,*n*) (declare (ignore i)) (cl-weave:expect t :to-be-truthy))))) (eval `(cl-weave:describe "detail-baseline" (cl-weave:it "case" (dotimes (i ,*n*) (declare (ignore i)) (cl-weave::record-assertion) (cl-weave::assert-expectation t (list :to-be-truthy) (quote (cl-weave:expect t :to-be-truthy))))))) (defun run-suite (name) (cl-weave:run name :reporter :sexp :stream *sink*)) (defun signature (events) (list (length events) (cl-weave:results-status events) (mapcar (function type-of) events))) (defun measure (label name sample order) (sb-ext:gc :full t) (let ((start (get-internal-real-time)) (bytes (sb-ext:get-bytes-consed))) (let ((events (run-suite name))) (format t "~A~C~D~C~D~C~D~C~D~C~S~%" label #\Tab sample #\Tab order #\Tab (- (get-internal-real-time) start) #\Tab (- (sb-ext:get-bytes-consed) bytes) #\Tab (signature events))))) (dotimes (i 5) (declare (ignore i)) (run-suite "detail-optimized") (run-suite "detail-baseline")) (format t "equivalent~C~S~%" #\Tab (equal (signature (run-suite "detail-optimized")) (signature (run-suite "detail-baseline")))) (dotimes (sample 40) (if (evenp sample) (progn (measure "optimized" "detail-optimized" sample 1) (measure "baseline" "detail-baseline" sample 2)) (progn (measure "baseline" "detail-baseline" sample 1) (measure "optimized" "detail-optimized" sample 2)))) (uiop:quit 0))
